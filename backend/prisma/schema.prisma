generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role
  createdAt      DateTime        @default(now())
  audits         AuditLog[]
  cases          Case[]
  citizenProfile CitizenProfile?
  officerProfile OfficerProfile?
}

model CitizenProfile {
  id                 String           @id @default(uuid())
  mobile             String
  addressLine1       String
  addressLine2       String?
  village            String?
  ward               String?
  city               String?
  district           String?
  state              String?
  pincode            String?
  governmentIdType   GovernmentIdType
  governmentIdNumber String
  isVerified         Boolean          @default(false)
  userId             String           @unique
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id])
}

model Case {
  id          String      @id @default(uuid())
  title       String
  description String
  status      CaseStatus  @default(OPEN)
  createdAt   DateTime    @default(now())
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  evidences   Evidence[]
  interviews  Interview[]
}

model Evidence {
  id            String         @id @default(uuid())
  type          EvidenceType
  fileUrl       String
  summary       String?
  createdAt     DateTime       @default(now())
  caseId        String
  case          Case           @relation(fields: [caseId], references: [id])
  videoAnalysis VideoAnalysis?
}

model VideoAnalysis {
  id         String   @id @default(uuid())
  persons    Int?
  vehicles   Int?
  plates     String?
  summary    String?
  evidenceId String   @unique
  evidence   Evidence @relation(fields: [evidenceId], references: [id])
}

model Interview {
  id         String              @id @default(uuid())
  transcript String?
  summary    String?
  language   String?
  createdAt  DateTime            @default(now())
  caseId     String
  behavior   BehavioralAnalysis?
  case       Case                @relation(fields: [caseId], references: [id])
}

model BehavioralAnalysis {
  id            String    @id @default(uuid())
  pauseDuration Float?
  speechRate    Float?
  eyeDirection  String?
  headDirection String?
  interviewId   String    @unique
  interview     Interview @relation(fields: [interviewId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  createdAt DateTime @default(now())
  userId    String
  caseId    String?
  details   String?
  user      User     @relation(fields: [userId], references: [id])
}

model Alert {
  id        String   @id @default(uuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  caseId    String
  severity  String   @default("HIGH")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
}

model OfficerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  gender            String?
  dob               DateTime?
  phone             String?
  alternatePhone    String?
  email             String?
  address           String?
  city              String?
  district          String?
  state             String?
  pincode           String?
  officerId         String?
  badgeNumber       String?
  rank              String?
  designation       String?
  department        String?
  station           String?
  bloodGroup        String?
  aadhaar           String?
  pan               String?
  photo             String?
  emergencyName     String?
  emergencyRelation String?
  emergencyPhone    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])
}

enum Role {
  CITIZEN
  OFFICER
  SUPERVISOR
  INVESTIGATOR
  ADMIN
}

enum GovernmentIdType {
  AADHAAR
  VOTER_ID
  DRIVING_LICENSE
  RATION_CARD
  OTHER
}

enum EvidenceType {
  VIDEO
  AUDIO
  IMAGE
  DOCUMENT
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}
